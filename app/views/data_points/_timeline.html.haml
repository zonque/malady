.card.card-pad.mb-6
  %h2.mb-3.font-semibold= t(".log_a_reading")
  #data_point_form= render "data_points/form", metric: metric, data_point: data_point
%ul#data_points.space-y-2
  - data_points.each do |dp|
    = render "data_points/data_point", metric: metric, data_point: dp
- if total_pages > 1
  %nav.mt-4.flex.items-center.justify-between.gap-2
    - if page > 1
      = link_to t(".newer"), metric_path(metric, page: page - 1), class: "btn btn-secondary btn-sm"
    - else
      %span
    %span.text-sm.text-gray-500.dark:text-gray-400= t(".page_of", page: page, total: total_pages)
    - if page < total_pages
      = link_to t(".older"), metric_path(metric, page: page + 1), class: "btn btn-secondary btn-sm"
    - else
      %span
