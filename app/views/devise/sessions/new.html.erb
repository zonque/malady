<h1 class="page-title mb-6"><%= t(".title") %></h1>

<div class="card card-pad space-y-4">
  <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
    <div>
      <%= f.label :email, class: "form-label" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-input" %>
    </div>

    <div>
      <%= f.label :password, class: "form-label" %>
      <%= f.password_field :password, autocomplete: "current-password", class: "form-input" %>
    </div>

    <% if devise_mapping.rememberable? %>
      <div class="flex items-center gap-2">
        <%= f.check_box :remember_me %>
        <%= f.label :remember_me, class: "text-sm text-gray-600 dark:text-gray-400" %>
      </div>
    <% end %>

    <div>
      <%= f.submit t(".submit"), class: "btn btn-primary w-full" %>
    </div>
  <% end %>
</div>

<div class="mt-4 space-y-1 text-sm">
  <%= render "devise/shared/links" %>
</div>
