!!!
%html{ lang: I18n.locale }
  %head
    %title= content_for(:title).presence || "Malady"
    %meta{ name: "viewport", content: "width=device-width,initial-scale=1" }
    %meta{ name: "apple-mobile-web-app-capable", content: "yes" }
    %meta{ name: "application-name", content: "Malady" }
    %meta{ name: "mobile-web-app-capable", content: "yes" }
    = csrf_meta_tags
    = csp_meta_tag

    = yield :head

    -# Favicon = the Malady stethoscope logo (emoji SVG in public/icon.svg)
    %link{ rel: "icon", href: "/icon.svg", type: "image/svg+xml" }
    %link{ rel: "apple-touch-icon", href: "/icon.svg" }

    = stylesheet_link_tag "tailwind", "data-turbo-track": "reload"
    = javascript_importmap_tags

  %body.min-h-screen.bg-gray-50.text-gray-900.antialiased.dark:bg-gray-950.dark:text-gray-100{ data: { controller: "dark-mode" } }
    %header{ class: "sticky top-0 z-10 border-b border-gray-200 bg-white/80 backdrop-blur dark:border-gray-800 dark:bg-gray-900/80" }
      %nav.mx-auto.flex.max-w-3xl.items-center.justify-between.gap-2.px-4.py-3
        = link_to "🩺 Malady", root_path, class: "flex items-center gap-2 text-lg font-bold tracking-tight"
        .flex.items-center.gap-1
          - if user_signed_in?
            = link_to t("nav.dashboard"), root_path, class: "nav-link"
            = link_to t("nav.overview"), overview_path, class: "nav-link"
            - if current_user.admin?
              = link_to t("nav.admin"), admin_users_path, class: "nav-link"
          %button.btn.btn-ghost.btn-sm{ type: "button", data: { action: "dark-mode#toggle" }, "aria-label": t("nav.toggle_dark_mode") }
            %span.inline.dark:hidden 🌙
            %span.hidden.dark:inline ☀️
          - if user_signed_in?
            %span{ class: "hidden text-sm text-gray-500 dark:text-gray-400 sm:inline", title: "Signed in" }= current_user.email
            = link_to t("nav.log_out"), destroy_user_session_path, class: "nav-link", data: { turbo_method: :delete }
    %main.mx-auto.max-w-3xl.px-4.py-6
      - if notice
        .alert.alert-success.mb-4= notice
      - if alert
        .alert.alert-error.mb-4= alert
      = yield
