-# Browser timezone is synced app-wide from the layout body; see application.html.haml.
%div
  .mb-6.flex.flex-wrap.items-center.justify-between.gap-3
    %h1.page-title= t(".title")
    .flex.gap-1
      - OverviewReport::PERIODS.each do |p|
        = link_to p.capitalize, overview_path(period: p, metrics: @selected_slugs), class: (p == @period ? "btn btn-primary btn-sm" : "btn btn-secondary btn-sm")
  - if @chartable_metrics.any?
    = form_with url: overview_path, method: :get, class: "card card-pad mb-6" do
      = hidden_field_tag :period, @period
      = hidden_field_tag "metrics[]", ""
      %div.mb-2.text-sm.font-medium= t(".plot_lines")
      .flex.flex-wrap.gap-x-4.gap-y-2
        - @chartable_metrics.each do |m|
          %label.flex.items-center.gap-1.text-sm
            = check_box_tag "metrics[]", m.slug, @selected_slugs.include?(m.slug), onchange: "this.form.requestSubmit()"
            = m.name
  - if @buckets.any?
    .space-y-8
      - @buckets.each do |bucket|
        %section
          %h2.mb-3.border-b.border-gray-200.pb-1.text-sm.font-semibold.uppercase.tracking-wide.text-gray-500.dark:border-gray-800.dark:text-gray-400= overview_period_label(bucket[:start], @period)
          - series = overview_chart_series(bucket[:entries], @selected_ids)
          - if series.any?
            .card.card-pad.mb-3
              .relative.h-64
                %canvas{ data: { controller: "overview-chart", "overview-chart-series-value": series.to_json, "overview-chart-period-value": @period } }
          .space-y-3
            - bucket[:entries].each do |entry|
              .card.card-pad
                .mb-2.flex.items-center.justify-between.gap-2
                  = link_to metric_path(entry[:metric]), class: "font-semibold text-gray-900 hover:text-indigo-600 dark:text-white dark:hover:text-indigo-400" do
                    = metric_icon_tag(entry[:metric], class: "mr-1 text-gray-500 dark:text-gray-400")
                    = entry[:metric].name
                  %span.badge= t("metrics.types.#{entry[:metric].data_type}")
                - if entry[:metric].note.present?
                  .metric-note.mb-2.text-xs.italic.text-gray-500.dark:text-gray-400= entry[:metric].note
                .mb-2.text-xs.text-gray-500.dark:text-gray-400
                  = t(".reading", count: entry[:count])
                  - if entry[:min]
                    %span.mx-1 ·
                    = t(".min_max_avg", min: overview_stat(entry[:min]), max: overview_stat(entry[:max]), avg: overview_stat(entry[:avg]))
                    - if entry[:metric].unit.present?
                      = entry[:metric].unit
                -# entry[:points] stays ascending for the chart; show newest first.
                %ul.divide-y.divide-gray-100.dark:divide-gray-800
                  - entry[:points].reverse_each do |dp|
                    %li.flex.items-center.justify-between.gap-2.py-1.text-sm
                      %span.shrink-0.text-gray-500.dark:text-gray-400= overview_point_time(dp.recorded_at, @period, current_user.time_zone, ignore_time: entry[:metric].ignore_time?)
                      = metric_value_display(entry[:metric], dp)
    - if @report.total_pages > 1
      %nav.mt-8.flex.items-center.justify-between.gap-2
        - if @report.page > 1
          = link_to t(".newer"), overview_path(period: @period, page: @report.page - 1, metrics: @selected_slugs), class: "btn btn-secondary btn-sm"
        - else
          %span
        %span.text-sm.text-gray-500.dark:text-gray-400= t(".page_of", page: @report.page, total: @report.total_pages)
        - if @report.page < @report.total_pages
          = link_to t(".older"), overview_path(period: @period, page: @report.page + 1, metrics: @selected_slugs), class: "btn btn-secondary btn-sm"
        - else
          %span
  - else
    .card.card-pad.text-center.text-gray-500.dark:text-gray-400= t(".no_data")
