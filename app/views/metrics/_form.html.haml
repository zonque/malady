= form_with model: metric, data: { controller: "metric-form" }, class: "card card-pad space-y-4" do |f|
  - if metric.errors.any?
    .alert.alert-error
      %ul.list-disc.pl-5
        - metric.errors.full_messages.each do |msg|
          %li= msg
  %div
    = f.label :name, class: "form-label"
    = f.text_field :name, class: "form-input"
  %div
    = f.label :data_type, class: "form-label"
    - type_options = Metric::DATA_TYPES.map { |t| [t("metrics.types.#{t}"), t] }
    - preset_options = Metric::PRESETS.keys.map { |k| [t("metrics.presets.#{k}"), k] }
    = f.select :data_type, type_options + preset_options, {}, class: "form-select", data: { metric_form_target: "type", action: "metric-form#toggleEnum" }
  %div
    = f.label :unit, class: "form-label"
    = f.text_field :unit, class: "form-input", placeholder: t(".unit_placeholder")
  %div{ data: { controller: "icon-picker" } }
    = f.label :icon, t(".icon_label"), class: "form-label"
    = f.hidden_field :icon, data: { icon_picker_target: "input" }
    .mb-2.flex.items-center.gap-3
      %i{ class: (metric.icon.present? ? "bi bi-#{metric.icon} text-2xl" : "bi bi-question-square text-2xl text-gray-300 dark:text-gray-600"), data: { icon_picker_target: "preview" }, "aria-hidden": "true" }
      = text_field_tag :icon_search, nil, placeholder: t(".icon_search_placeholder"), class: "form-input flex-1", autocomplete: "off", data: { icon_picker_target: "search", action: "input->icon-picker#filter" }
      %button.btn.btn-secondary.btn-sm{ type: "button", data: { action: "icon-picker#clear" } }= t(".icon_clear")
    .grid.max-h-56.grid-cols-8.gap-2.overflow-y-auto.rounded-lg.border.border-gray-200.p-2.dark:border-gray-800{ data: { icon_picker_target: "grid", action: "scroll->icon-picker#scroll" } }
    %p.form-hint.mt-1
      = t(".icon_count_label")
      %span.tabular-nums{ data: { icon_picker_target: "count" } }
  %div
    = f.label :note, class: "form-label"
    = f.text_field :note, class: "form-input", placeholder: t(".note_placeholder")
  %div
    %label.flex.items-center.gap-2
      = f.check_box :ignore_time, class: "form-checkbox"
      %span.form-label.mb-0= t(".ignore_time_label")
  %div{ data: { metric_form_target: "enumWrapper", controller: "enum-options" } }
    = render "metrics/enum_options", f: f
  .flex.gap-2.pt-2
    = f.submit class: "btn btn-primary"
    = link_to t(".cancel"), root_path, class: "btn btn-secondary"
