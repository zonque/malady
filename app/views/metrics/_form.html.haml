= form_with model: metric, data: { controller: "metric-form" }, class: "card card-pad space-y-4" do |f|
  - if metric.errors.any?
    .alert.alert-error
      %ul.list-disc.pl-5
        - metric.errors.full_messages.each do |msg|
          %li= msg
  %div
    = f.label :name, class: "form-label"
    = f.text_field :name, class: "form-input"
  %div
    = f.label :data_type, class: "form-label"
    - type_options = Metric::DATA_TYPES.map { |t| [t("metrics.types.#{t}"), t] }
    - preset_options = Metric::PRESETS.keys.map { |k| [t("metrics.presets.#{k}"), k] }
    = f.select :data_type, type_options + preset_options, {}, class: "form-select", data: { metric_form_target: "type", action: "metric-form#toggleEnum" }
  %div
    = f.label :unit, class: "form-label"
    = f.text_field :unit, class: "form-input", placeholder: t(".unit_placeholder")
  %div
    %label.flex.items-center.gap-2
      = f.check_box :ignore_time, class: "form-checkbox"
      %span.form-label.mb-0= t(".ignore_time_label")
  %div{ data: { metric_form_target: "enumWrapper", controller: "enum-options" } }
    = render "metrics/enum_options", f: f
  .flex.gap-2.pt-2
    = f.submit class: "btn btn-primary"
    = link_to t(".cancel"), root_path, class: "btn btn-secondary"
