.card.card-pad
  %h1.page-title.mb-1= t(".title")
  %p.text-sm.text-gray-500.dark:text-gray-400.mb-4= t(".description")
  %code.block.font-mono.break-all.rounded.bg-gray-100.dark:bg-gray-800.p-3.select-all.text-sm= current_user.api_token
  %p.mt-4.text-sm.font-medium= t(".endpoints")
  %ul.mt-1.text-sm.font-mono.text-gray-600.dark:text-gray-400.space-y-1
    %li GET /api/v1/metrics
    %li GET /api/v1/metrics/:slug/series?from=&to=
  = button_to t(".regenerate"), api_token_path, method: :patch, data: { turbo_confirm: t(".regenerate_confirm") }, class: "btn btn-danger mt-6"
